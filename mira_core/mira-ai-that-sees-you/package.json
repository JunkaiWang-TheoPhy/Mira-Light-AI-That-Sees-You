{
  "name": "mira-released-version",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20 <26"
  },
  "workspaces": [
    "core/plugins/lingzhu-bridge",
    "modules/home-assistant/plugin",
    "services/notification-router",
    "services/lingzhu-live-adapter"
  ],
  "scripts": {
    "verify:release": "node scripts/verify-release.mjs",
    "test:release": "node --test scripts/__tests__/*.test.mjs",
    "export:repo": "node scripts/export-release-repo.mjs",
    "manifest:deploy": "node scripts/repo-deploy-runtime.mjs manifest",
    "bootstrap": "node scripts/repo-deploy-runtime.mjs bootstrap",
    "doctor": "node scripts/repo-deploy-runtime.mjs doctor",
    "start": "node scripts/repo-deploy-runtime.mjs start",
    "start:all": "node scripts/repo-deploy-runtime.mjs start",
    "deploy": "node scripts/repo-deploy-runtime.mjs deploy",
    "deploy:all": "node scripts/repo-deploy-runtime.mjs deploy",
    "status": "node scripts/repo-deploy-runtime.mjs status",
    "status:all": "node scripts/repo-deploy-runtime.mjs status",
    "health": "node scripts/repo-deploy-runtime.mjs health",
    "health:all": "node scripts/repo-deploy-runtime.mjs health",
    "self-check": "node scripts/repo-deploy-runtime.mjs self-check",
    "self-check:all": "node scripts/repo-deploy-runtime.mjs self-check",
    "down": "node scripts/repo-deploy-runtime.mjs down",
    "down:all": "node scripts/repo-deploy-runtime.mjs down",
    "bootstrap:notification-router": "node scripts/notification-router-runtime.mjs bootstrap",
    "deploy:notification-router": "node scripts/notification-router-runtime.mjs deploy",
    "doctor:notification-router": "node scripts/notification-router-runtime.mjs doctor",
    "start:notification-router": "node scripts/notification-router-runtime.mjs start",
    "up:notification-router": "node scripts/notification-router-runtime.mjs up",
    "status:notification-router": "node scripts/notification-router-runtime.mjs status",
    "down:notification-router": "node scripts/notification-router-runtime.mjs down",
    "health:notification-router": "node scripts/notification-router-runtime.mjs health",
    "self-check:notification-router": "node scripts/notification-router-runtime.mjs self-check",
    "bootstrap:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs bootstrap",
    "deploy:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs deploy",
    "doctor:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs doctor",
    "start:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs start",
    "start:lingzhu-live-adapter": "npm --workspace @mira/lingzhu-live-adapter run start",
    "up:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs up",
    "status:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs status",
    "down:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs down",
    "health:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs health",
    "self-check:mira-openclaw": "node scripts/mira-openclaw-runtime.mjs self-check"
  }
}
