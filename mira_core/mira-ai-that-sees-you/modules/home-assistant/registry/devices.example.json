    {
      "id": "mi-bedroom-fan",
      "displayName": "Bedroom Fan",
      "ecosystemId": "xiaomi-home",
      "vendor": "xiaomi",
      "integration": "home_assistant",
      "connectionMode": "hybrid",
      "directAdapter": "xiaomi-miot",
      "kind": "fan",
      "area": "bedroom",
      "entityId": "fan.mi_bedroom",
      "aliases": [
        "bedroom fan",
        "mi fan",
        "xiaomi fan"
      ],
      "traits": [
        "actuator",
        "climate_comfort"
      ],
      "externalIds": {
        "miotDid": "12345"
      },
      "capabilityProfiles": [
        "power.basic",
        "fan.percentage"
      ],
      "capabilities": [
        {
          "intent": "turn_on",
          "domain": "fan",
          "service": "turn_on",
          "riskTier": "side_effect"
        },
        {
          "intent": "turn_off",
          "domain": "fan",
          "service": "turn_off",
          "riskTier": "side_effect"
        },
        {
          "intent": "set_percentage",
          "domain": "fan",
          "service": "set_percentage",
          "dataTemplate": {
            "percentage": "{{value}}"
          },
          "supportedValues": {
            "type": "number",
            "minimum": 1,
            "maximum": 100
          },
          "requiresConfirmation": true,
          "riskTier": "side_effect"
        }
      ],
      "sceneBindings": [
        {
          "role": "cooling.primary_fan",
          "priority": 100
        },
        {
          "role": "arrival.cooling_target",
          "priority": 90
        }
      ],
      "stateHints": {
        "presenceSensitive": false,
        "quietHoursRelevant": true
      }
    },
