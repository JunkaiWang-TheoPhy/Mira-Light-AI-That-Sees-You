{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mira-light.local/schemas/mira_light_vision_event.schema.json",
  "title": "Mira Light Vision Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "timestamp",
    "source",
    "frame",
    "tracking",
    "scene_hint"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "target_seen",
        "target_updated",
        "target_lost",
        "no_target"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pipeline",
        "camera_mode",
        "distance_mode"
      ],
      "properties": {
        "pipeline": {
          "type": "string",
          "enum": [
            "saved_jpeg_watch"
          ]
        },
        "camera_mode": {
          "type": "string",
          "enum": [
            "single_camera_2d"
          ]
        },
        "distance_mode": {
          "type": "string",
          "enum": [
            "monocular_heuristic"
          ]
        }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "width",
        "height"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "seq": {
          "type": [
            "string",
            "null"
          ]
        },
        "capture_ts": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_present",
        "target_class",
        "detector",
        "confidence"
      ],
      "properties": {
        "target_present": {
          "type": "boolean"
        },
        "target_class": {
          "type": "string",
          "enum": [
            "person",
            "face",
            "motion_blob",
            "unknown",
            "none"
          ]
        },
        "detector": {
          "type": "string",
          "enum": [
            "haar_face",
            "background_motion",
            "none"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "bbox_norm": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "w",
            "h"
          ],
          "properties": {
            "x": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "y": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "w": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "h": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        },
        "center_norm": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "x",
            "y"
          ],
          "properties": {
            "x": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "y": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        },
        "horizontal_zone": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right",
            "unknown"
          ]
        },
        "vertical_zone": {
          "type": "string",
          "enum": [
            "upper",
            "middle",
            "lower",
            "unknown"
          ]
        },
        "size_norm": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0,
          "maximum": 1.0
        },
        "distance_band": {
          "type": "string",
          "enum": [
            "near",
            "mid",
            "far",
            "unknown"
          ]
        },
        "approach_state": {
          "type": "string",
          "enum": [
            "approaching",
            "receding",
            "stable",
            "unknown"
          ]
        }
      }
    },
    "scene_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "wake_up",
            "curious_observe",
            "track_target",
            "sleep",
            "none"
          ]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "control_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "yaw_error_norm",
        "pitch_error_norm",
        "lift_intent",
        "reach_intent"
      ],
      "properties": {
        "yaw_error_norm": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0
        },
        "pitch_error_norm": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0
        },
        "lift_intent": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "reach_intent": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "raw_measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_age_ms"
      ],
      "properties": {
        "frame_age_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0
        },
        "bbox_area_px": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0
        },
        "size_delta_norm": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  }
}
