# Generated local runtime env for the release-safe Mira + OpenClaw pack.

# Optional repo fallback provider. Leave these as replace-me when the host
# OpenClaw already has a usable default provider. Otherwise either set
# OPENAI_API_KEY or provide explicit MIRA_OPENCLAW_PROVIDER_* overrides.
# If the host OpenClaw uses a named profile such as `main`, Mira now tries to
# auto-detect it from workspace paths like `.../workspace-openclaw-agents/main/...`.
# Use these only when you need to override that detection.
MIRA_OPENCLAW_HOST_PROFILE=
MIRA_OPENCLAW_HOST_CONFIG_PATH=
OPENAI_API_KEY=
OPENAI_BASE_URL=
MIRA_OPENCLAW_PROVIDER_ID=replace-me-provider
MIRA_OPENCLAW_PROVIDER_BASE_URL=https://api.example.com/v1
MIRA_OPENCLAW_PROVIDER_API=openai-responses
MIRA_OPENCLAW_PROVIDER_API_KEY=replace-me
MIRA_OPENCLAW_MODEL_ID=gpt-5.4
MIRA_OPENCLAW_MODEL_NAME=gpt-5.4

# Stack defaults applied regardless of provider source.
MIRA_OPENCLAW_USER_TIMEZONE=Asia/Shanghai
MIRA_OPENCLAW_ENABLE_LEGACY_LINGZHU=false
MIRA_OPENCLAW_MEMORY_CONTEXT_ENABLED=false
MIRA_OPENCLAW_MEMORY_CONTEXT_URL=http://127.0.0.1:3301/v1/memory/context
MIRA_OPENCLAW_GATEWAY_PORT=18790
MIRA_OPENCLAW_HEALTH_TIMEOUT_MS=45000
MIRA_OPENCLAW_ENABLE_NOTIFICATION_ROUTER=true
MIRA_OPENCLAW_ENABLE_LINGZHU_ADAPTER=true

# Repo-owned Lingzhu live adapter. This is the preferred public entrypoint.
MIRA_LINGZHU_AUTH_AK=replace-me
MIRA_LINGZHU_ADAPTER_PORT=18789
MIRA_LINGZHU_AGENT_ID=main
MIRA_LINGZHU_SESSION_MODE=per_user
MIRA_LINGZHU_SESSION_NAMESPACE=mira-lingzhu-prod
MIRA_LINGZHU_MEMORY_STORE_PATH=

# Optional override. If left as replace-me and a local `openclaw` binary exists,
# the runtime falls back to: openclaw gateway run --port $MIRA_OPENCLAW_GATEWAY_PORT
OPENCLAW_START_COMMAND=replace-me
