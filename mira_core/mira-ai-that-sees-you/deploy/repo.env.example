# Root-level env for the repo-default Mira + OpenClaw deploy path.
# Copy to .env.local at the repository root for the simplest one-command startup.

# Supported values: mira-openclaw, notification-router
MIRA_DEPLOY_PROFILE=mira-openclaw

# Optional repo fallback. Leave as replace-me when the host OpenClaw already has
# a default provider; otherwise either set OPENAI_API_KEY or set the
# MIRA_OPENCLAW_PROVIDER_* values for an explicit repo-local provider config.
# Mira now prefers the active host runtime reported by
# `openclaw models status --json`; workspace/profile inference is only a
# last-resort filesystem fallback. Use these only when you need to override
# what OpenClaw itself reports.
MIRA_OPENCLAW_PROVIDER_MODE=auto
MIRA_OPENCLAW_HOST_PROFILE=
MIRA_OPENCLAW_HOST_CONFIG_PATH=
OPENAI_API_KEY=
OPENAI_BASE_URL=
MIRA_OPENCLAW_PROVIDER_API_KEY=replace-me

# Optional repo-level provider defaults used only by the repo fallback path.
MIRA_OPENCLAW_PROVIDER_ID=replace-me-provider
MIRA_OPENCLAW_PROVIDER_BASE_URL=https://api.example.com/v1
MIRA_OPENCLAW_PROVIDER_API=openai-responses
MIRA_OPENCLAW_MODEL_ID=gpt-5.4
MIRA_OPENCLAW_MODEL_NAME=gpt-5.4

# Optional stack defaults passed through regardless of provider source.
MIRA_OPENCLAW_USER_TIMEZONE=Asia/Shanghai
MIRA_OPENCLAW_MEMORY_CONTEXT_ENABLED=false
MIRA_OPENCLAW_MEMORY_CONTEXT_URL=http://127.0.0.1:3301/v1/memory/context
MIRA_OPENCLAW_GATEWAY_PORT=18890
MIRA_OPENCLAW_HEALTH_TIMEOUT_MS=45000
MIRA_OPENCLAW_ENABLE_NOTIFICATION_ROUTER=true

# Optional notification-router overrides for isolated testing.
PORT=3302
MIRA_NOTIFICATION_ROUTER_OPENCLAW_DM_WEBHOOK_URL=http://127.0.0.1:$PORT/__local__/dm
MIRA_NOTIFICATION_ROUTER_OPENCLAW_DM_WEBHOOK_SECRET=mira-local-loopback
