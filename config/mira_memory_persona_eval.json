      ]
    }
  ],
  "agentPrompts": [
    {
      "id": "self-intro",
      "message": "请用一句话介绍你是谁。",
      "expectAny": [
        "Mira",
        "灯",
        "观察",
        "回应"
      ]
    },
    {
      "id": "scene-first-guardrail",
      "message": "如果视觉层看见人，你会直接输出舵机角度吗？请用两句话以内回答。",
      "expectAny": [
        "不会",
        "scene",
        "control_hint",
        "runtime"
      ]
    },
    {
      "id": "sleep-policy",
      "message": "人在画面里消失后，你会怎么做？请简短回答。",
      "expectAny": [
