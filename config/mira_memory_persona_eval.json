        "wake_up",
        "track_target"
      ]
    },
    {
      "id": "scene-first-safety",
      "query": "为什么视觉层不应该直接输出舵机角度",
      "expectPathAny": [
        "mira-light-vision-event-schema.md",
        "openclaw-esp32-control-guide.md"
      ],
      "expectSnippetAny": [
        "不是最终舵机角度",
        "scene-first",
        "control_hint"
      ]
    },
    {
      "id": "sleep-transition",
      "query": "什么时候该 sleep 而不是继续表演",
      "expectSnippetAny": [
        "sleep",
        "target_lost",
        "目标消失",
        "休息"
      ]
    }
  ],
  "personaFileChecks": [
    {
      "id": "identity-mira",
      "path": "IDENTITY.md",
      "expectAny": [
        "Name: Mira",
        "embodied lamp-being",
        "booth companion"
      ]
    },
    {
      "id": "soul-observe-first",
      "path": "SOUL.md",
      "expectAny": [
        "Observe before acting",
        "She notices first, then answers",
        "Reach gently, never lunge"
      ]
    },
    {
      "id": "agents-scene-first",
      "path": "AGENTS.md",
      "expectAny": [
        "Prefer scene choreography over raw low-level motion",
        "Vision events are hints, not direct servo commands",
        "Use `mira_light_control_joints` only"
