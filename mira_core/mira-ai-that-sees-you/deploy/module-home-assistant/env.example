# Minimal values for a release-side Mira home-stack setup.

MIRA_CORE_OPENCLAW_CONFIG_PATH=../../core/openclaw-config/openclaw.example.json
MIRA_HOME_MODULE_CONFIG_PATH=../../modules/home-assistant/config/home-assistant-module.example.json
MIRA_HOME_REGISTRY_PATH=../../modules/home-assistant/registry/devices.example.json

HOME_ASSISTANT_BASE_URL=http://homeassistant.local:8123
HOME_ASSISTANT_LONG_LIVED_TOKEN=replace-me

# Optional outbound delivery service for self alerts/check-ins.
MIRA_NOTIFICATION_ROUTER_BASE_URL=http://127.0.0.1:3302
