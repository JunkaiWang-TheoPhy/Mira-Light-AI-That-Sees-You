# Shared runtime target
MIRA_LIGHT_LAMP_BASE_URL=http://172.20.10.3
MIRA_LIGHT_DRY_RUN=0

# Director console
MIRA_LIGHT_CONSOLE_HOST=127.0.0.1
MIRA_LIGHT_CONSOLE_PORT=8765
MIRA_LIGHT_CONSOLE_BRIDGE_URL=http://127.0.0.1:9783
MIRA_LIGHT_CONSOLE_BRIDGE_TIMEOUT_SECONDS=5
MIRA_LIGHT_CONSOLE_BRIDGE_TOKEN_ENV=MIRA_LIGHT_BRIDGE_TOKEN

# Simple receiver
MIRA_LIGHT_RECEIVER_HOST=0.0.0.0
MIRA_LIGHT_RECEIVER_PORT=9784
MIRA_LIGHT_RECEIVER_SAVE_ROOT=${HOME}/Documents/Mira-Light-Runtime/simple-receiver

# Bridge
MIRA_LIGHT_BRIDGE_HOST=127.0.0.1
MIRA_LIGHT_BRIDGE_PORT=9783
MIRA_LIGHT_BRIDGE_TOKEN=test-token
MIRA_LIGHT_BRIDGE_URL=http://127.0.0.1:9783
MIRA_LIGHT_BRIDGE_TIMEOUT_MS=5000

# Bootstrap behavior
MIRA_LIGHT_SKIP_OPENCLAW_INSTALL=0
