# notification-router runtime
PORT=3302

# direct-message channel
MIRA_NOTIFICATION_ROUTER_OPENCLAW_DM_WEBHOOK_URL=http://127.0.0.1:3400/hook
MIRA_NOTIFICATION_ROUTER_OPENCLAW_DM_WEBHOOK_SECRET=replace-me

# Resend-backed email channel
MIRA_NOTIFICATION_ROUTER_RESEND_API_KEY=re_replace_me
MIRA_NOTIFICATION_ROUTER_RESEND_FROM=Mira <mira@example.com>
MIRA_NOTIFICATION_ROUTER_RESEND_REPLY_TO=user@example.com

# Optional override for local testing only.
# MIRA_NOTIFICATION_ROUTER_RESEND_API_BASE_URL=http://127.0.0.1:3500
